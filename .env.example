# EPT-Kompass environment variables.
# Copy to `.env.local` for local dev; configure the same keys in Vercel for prod.
#
# MVP runs the app without Supabase (filesystem-backed content), so these are
# optional for local dev. Populate them to run the seed script or wire up auth.

# Supabase project URL — "https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon (public) key. Safe to expose; RLS enforces access.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key. NEVER commit; used only by `npm run seed`
# and server-only routes. Leave blank in client-only environments.
SUPABASE_SERVICE_ROLE_KEY=

# Absolute URL of the deployed app (no trailing slash). Used for
# magic-link redirects and canonical metadata.
NEXT_PUBLIC_APP_URL=http://localhost:3000
